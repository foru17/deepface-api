# All variables use the DEEPFACE_ prefix; legacy unprefixed forms are still
# honored for backwards compatibility but new code should use the prefixed
# form. See `src/deepface_api/config.py` for the full list.

DEEPFACE_SERVER_HOST=0.0.0.0
DEEPFACE_SERVER_PORT=8008

DEEPFACE_OUTPUT_DIR=./output
DEEPFACE_MAX_UPLOAD_SIZE_MB=10

# Logging
DEEPFACE_LOG_LEVEL=INFO
DEEPFACE_LOG_JSON=false

# CORS — comma-separated origins, or "*"
DEEPFACE_CORS_ORIGINS=*
DEEPFACE_CORS_ALLOW_CREDENTIALS=false

# Toggle the /docs and /redoc routes (disable in production if desired)
DEEPFACE_ENABLE_DOCS=true

# TensorFlow log spam
TF_CPP_MIN_LOG_LEVEL=2
